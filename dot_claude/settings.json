{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_TELEMETRY_DISABLED": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(stat *)",
      "Bash(file *)",
      "Bash(du *)",
      "Bash(tree *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git remote *)",
      "Bash(git blame *)",
      "Bash(which *)",
      "WebSearch",
      "WebFetch",
      "Glob",
      "Read"
    ],
    "deny": [
      "Read(*.key)",
      "Read(*.pem)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.development)",
      "Read(.env.staging)",
      "Read(.env.production)",
      "Read(.env.test)",
      "Read(secrets/**)",
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ],
    "ask": [
      "Bash(git add *)",
      "Bash(git push *)",
      "Bash(git commit *)"
    ]
  },
  "deniedMcpServers": [
    {
      "serverName": "filesystem"
    }
  ],
  "feedbackSurveyRate": 0,
  "effortLevel": "medium",
  "plansDirectory": ".plans",
  "parallelTasksCount": 3,
  "showTurnDuration": true
}
