{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "alwaysThinkingEnabled": true,
  "parallelTasksCount": 3,
  "feedbackSurveyRate": 0,
  "showTurnDuration": true,
  "plansDirectory": "./plans",
  "attribution": {
    "commits": false,
    "pullRequests": false
  },
  "permissions": {
    "allow": [
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep * *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(stat *)",
      "Bash(file *)",
      "Bash(du *)",
      "Bash(tree *)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git remote:*)",
      "Bash(git blame:*)",
      "WebSearch",
      "Glob",
      "Read"
    ],
    "ask": [
      "WebFetch",
      "Bash(git push:*)",
      "Bash(git commit:*)"
    ],
    "deny": [
      "Read(*.key)",
      "Read(*.pem)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(secrets/**)",
      "Bash(rm -rf:*)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ]
  },
  "deniedMcpServers": [
    {
      "serverName": "filesystem"
    }
  ],
  "env": {
    "CLAUDE_TELEMETRY_DISABLED": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80"
  }
}
