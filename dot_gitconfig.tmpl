[user]
	name = {{ .git_name }}
	email = {{ .git_email }}
	signingkey = {{ .git_signingkey }}
[core]
	pager = delta
	ignorecase = false
	editor = vim
[delta]
	features = catppuccin-latte
	navigate = true
	side-by-side = true
	line-numbers = true
[gpg]
	format = ssh
	program = /opt/homebrew/bin/gpg
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
[commit]
	gpgsign = true
[interactive]
	diffFilter = delta --color-only
[merge]
	conflictstyle = diff3
[diff]
	colorMoved = default
[pull]
	rebase = false
	ff = only
[init]
	defaultBranch = main
[push]
	autoSetupRemote = true
[advice]
	addEmptyPathspec = false
