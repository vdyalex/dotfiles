{
  "[dockercompose]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-containers"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[php]": {
    "editor.defaultFormatter": "open-southeners.laravel-pint"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "chat.disableAIFeatures": true,
  "chat.extensionUnification.enabled": false,
  "chat.mcp.gallery.enabled": true,
  "claudeCode.initialPermissionMode": "plan",
  "claudeCode.preferredLocation": "panel",
  "claudeCode.selectedModel": "sonnet",
  "containers.contexts.showInStatusBar": true,
  "debug.console.fontSize": 15,
  "dev.containers.dockerComposePath": "docker compose",
  "diffEditor.codeLens": true,
  "diffEditor.experimental.showMoves": true,
  "diffEditor.experimental.useTrueInlineView": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "diffEditor.renderSideBySide": false,
  "docker.extension.dockerEngineAvailabilityPrompt": false,
  "docker.extension.enableComposeLanguageServer": false,
  "editor.accessibilitySupport": "off",
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "editor.cursorBlinking": "phase",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorStyle": "line",
  "editor.find.autoFindInSelection": "multiline",
  "editor.fontFamily": "'Operator Mono Lig Book'",
  "editor.fontLigatures": true,
  "editor.fontSize": 15,
  "editor.fontWeight": "400",
  "editor.formatOnPaste": false,
  "editor.formatOnSave": true,
  "editor.formatOnType": false,
  "editor.glyphMargin": true,
  "editor.inlineSuggest.enabled": true,
  "editor.lineHeight": 24,
  "editor.minimap.autohide": "mouseover",
  "editor.minimap.enabled": true,
  "editor.minimap.maxColumn": 100,
  "editor.parameterHints.cycle": true,
  "editor.quickSuggestionsDelay": 0,
  "editor.renderControlCharacters": true,
  "editor.rulers": [
    100
  ],
  "editor.scrollBeyondLastLine": false,
  "editor.smoothScrolling": true,
  "editor.suggest.shareSuggestSelections": true,
  "editor.suggestOnTriggerCharacters": false,
  "editor.suggestSelection": "first",
  "editor.tabCompletion": "on",
  "editor.tabSize": 2,
  "editor.wordWrapColumn": 80,
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "extensions.autoUpdate": "onlyEnabledExtensions",
  "files.defaultLanguage": "typescript",
  "files.eol": "\n",
  "files.exclude": {
    "**/.classpath": true,
    "**/.DS_Store": true,
    "**/.factorypath": true,
    "**/.git": true,
    "**/.hg": true,
    "**/.project": true,
    "**/.settings": true,
    "**/.svn": true,
    "**/.vscode/": false,
    "**/bower_components/": true,
    "**/node_modules/": false
  },
  "files.hotExit": "onExitAndWindowClose",
  "files.insertFinalNewline": true,
  "files.simpleDialog.enable": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "git.confirmSync": false,
  "git.ignoreMissingGitWarning": true,
  "github.gitProtocol": "ssh",
  "githubRepositories.autoFetch.enabled": false,
  "json.maxItemsComputed": 3000,
  "laravel-pint.enable": true,
  "makefile.configureOnOpen": true,
  "markdown.extension.completion.enabled": true,
  "markdown.occurrencesHighlight.enabled": true,
  "markdown.preview.scrollEditorWithPreview": false,
  "markdown.validate.enabled": true,
  "scm.alwaysShowRepositories": true,
  "scm.defaultViewMode": "tree",
  "scm.inputFontSize": 14,
  "search.quickOpen.includeSymbols": true,
  "search.showLineNumbers": true,
  "search.smartCase": true,
  "search.useGlobalIgnoreFiles": true,
  "security.workspace.trust.untrustedFiles": "prompt",
  "settingsSync.ignoredSettings": [
    "-containers.containerClient"
  ],
  "telemetry.feedback.enabled": false,
  "telemetry.telemetryLevel": "off",
  "terminal.explorerKind": "external",
  "terminal.external.osxExec": "iTerm.app",
  "terminal.external.windowsExec": "",
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.fontFamily": "FiraCode Nerd Font Mono",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.gpuAcceleration": "on",
  "typescript.implementationsCodeLens.enabled": true,
  "typescript.referencesCodeLens.enabled": true,
  "update.mode": "start",
  "window.autoDetectColorScheme": true,
  "window.autoDetectHighContrast": false,
  "window.closeWhenEmpty": true,
  "window.customTitleBarVisibility": "windowed",
  "window.newWindowDimensions": "maximized",
  "window.openFoldersInNewWindow": "off",
  "window.restoreWindows": "preserve",
  "window.title": "${appName}${separator}${activeEditorShort}${separator}${folderPath}${separator}${dirty}",
  "workbench.editor.autoLockGroups": {
    "workbench.editor.chatSession": true
  },
  "workbench.iconTheme": "catppuccin-latte",
  "workbench.preferredDarkColorTheme": "Catppuccin Mocha",
  "workbench.preferredLightColorTheme": "Catppuccin Latte"
}
